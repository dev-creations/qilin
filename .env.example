# --- Ollama (host) ---
# nomic-embed-text-v2-moe must be pulled on the host: `ollama pull nomic-embed-text-v2-moe`
OLLAMA_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text-v2-moe
EMBEDDING_DIM=768

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- Memory defaults ---
DEFAULT_COLLECTION=memory

# --- Chunking ---
# nomic-embed-text-v2-moe has a 512-token context window; stay well below it.
CHUNK_SIZE_TOKENS=450
CHUNK_OVERLAP_TOKENS=50
EMBED_BATCH_SIZE=16

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8443
# Optional plain-HTTP listener (bound to 127.0.0.1 on the host in compose).
# Useful for local clients that don't trust the self-signed cert (e.g. Cursor).
# Set MCP_HTTP_ENABLED=0 to disable.
MCP_HTTP_PORT=8080
MCP_HTTP_ENABLED=1
TLS_CERT_FILE=/certs/cert.pem
TLS_KEY_FILE=/certs/key.pem
